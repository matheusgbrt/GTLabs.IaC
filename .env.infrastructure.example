POSTGRES_DB=gtlabs
POSTGRES_USER=gtlabs
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432

REDIS_PORT=6379

RABBITMQ_USER=gtlabs
RABBITMQ_PASSWORD=replace-with-a-strong-rabbitmq-password
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

CONSUL_HTTP_PORT=8500
CONSUL_DNS_PORT=8600

FABIO_HTTP_PORT=9999
FABIO_UI_PORT=9998

SEQ_PORT=5341
JAEGER_UI_PORT=16686
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8889

# Use http://fabio:9999 for services running on the gtlabs Docker network.
# Use http://<homelab-host-ip>:9999 for services running outside Docker.
GATEWAY_URL=http://fabio:9999

SEQ_URL=http://seq:5341
OTEL_OTLP_ENDPOINT=http://otel-collector:4317

JWT_ISSUER=gtlabs-auth
JWT_AUDIENCE=gtlabs-services
# Must be at least 32 bytes for HS256 validation in Gtlabs.Authentication.
JWT_SECRET_KEY=replace-with-a-real-32-byte-minimum-secret
